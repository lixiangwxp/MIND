    "version": "0.2.0",
    "configurations": [
        {
            "name": "MIND: 单步看 train 数据流",
            "type": "debugpy",
            "request": "launch",
            "python": "/opt/anaconda3/envs/mind/bin/python",
            "program": "${workspaceFolder}/src/train.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "stopOnEntry": false,
            "args": [
                "--disable-wandb",
                "--log-interval",
                "1"
            ],
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        },
        {
            "name": "MIND: 调试 dev evaluate 流程",
            "type": "debugpy",
            "request": "launch",
            "python": "/opt/anaconda3/envs/mind/bin/python",
            "program": "${workspaceFolder}/src/train.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "stopOnEntry": false,
            "args": [
                "--disable-wandb",
                "--log-interval",
                "10000"
            ],
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        },
        
        {
            "name": "Python 调试程序: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}
